# ── Auth.js (NextAuth v5) ──────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# App origin (no trailing slash). Local example:
AUTH_URL=http://localhost:3000
# Production example:
# AUTH_URL=https://your-domain.com

# ── Discord OAuth application ──────────────────────────────────────
# Discord Developer Portal → Your Application → OAuth2
# Redirects → add:
#   http://localhost:3000/api/auth/callback/discord
#   https://your-domain.com/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ── Discord guild auto-join (bot + guilds.join) ────────────────────
# Same application → Bot → Reset Token (copy once).
# Invite the bot into the Anikura server with permission:
#   Create Instant Invite (or Manage Server).
# OAuth2 scopes used by the app: identify, email, guilds.join
#
# Guild ID for invite https://discord.gg/cm72gXTASn
# (resolved via Discord invite API — confirm in Server Settings → Widget)
DISCORD_GUILD_ID=1528840790221131806
DISCORD_BOT_TOKEN=
