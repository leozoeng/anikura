# Supabase (required for auth, admin, presence)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Public site origin for auth confirmation emails (no trailing slash).
# Set this in Coolify (build args + runtime) / any host. Never use localhost
# in Production — phones can't open it. Code also hard-falls back to
# https://anikura.club if this is missing or set to localhost in production.
NEXT_PUBLIC_SITE_URL=https://anikura.club

# Server-only — used by /api/cron/catalog-sync to write live catalog overlays
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Protects cron → /api/cron/catalog-sync (Authorization: Bearer …)
# On Hetzner/Coolify: schedule a daily curl (see deploy/coolify.md)
CRON_SECRET=generate_a_long_random_string

# Admin access — ONLY these emails can open /admin (comma-separated).
# New signups are always normal users. Admins must still pass the Discord gate.
ADMIN_EMAIL=your_admin@example.com

# --- Members-only Discord gate ---
# 1) Discord Developer Portal → Bot → enable **Server Members Intent**
# 2) Invite the bot to the Anikura server
# 3) Guild ID must be the *server* snowflake (not a channel). For invite
#    https://discord.gg/cm72gXTASn the guild id is 1528840790221131806
# 4) Supabase → Authentication → Providers → Discord + “Allow manual linking”
DISCORD_GUILD_ID=1528840790221131806
DISCORD_BOT_TOKEN=your_discord_bot_token
# Optional: comma-separated emails that skip Discord onboarding (special cases).
# DISCORD_BYPASS_EMAILS=someone@example.com
